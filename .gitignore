# ====================================
# FRONTEND (React / Node)
# ====================================
node_modules/
dist/
server/public/
vite.config.ts.*
*.tar.gz

# ====================================
# BACKEND (Flask / Python)
# ====================================
# Virtual environments
aiinterview_env/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs and temporary files
*.log
logs/
tmp/
temp/
*.pid

# Configuration and credentials
*.env
.env.*
config.json

# ====================================
# AI/ML & Model-related
# ====================================
# Model weights / checkpoints
*.pt
*.pth
*.h5
*.pkl
*.ckpt

# Large binaries
*.dll
*.lib
*.so
*.dylib

# Data folders
data/
datasets/
media/
uploads/
outputs/
analysis_output_*/

# ====================================
# IDE / OS files
# ====================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ====================================
# Documentation and config normalization
# ====================================
* text=auto eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.sh   text eol=lf

# Ignore binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
